# ─────────────────────────────────────────────────────────────────
#  AgriSense AI – Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────

# IBM Cloud API Key  (https://cloud.ibm.com/iam/apikeys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM watsonx.ai Project ID  (https://dataplatform.cloud.ibm.com)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai API URL  (choose the region closest to you)
# US South : https://us-south.ml.cloud.ibm.com
# EU-DE    : https://eu-de.ml.cloud.ibm.com
# JP-TOK   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key – change this to a long random string in production
FLASK_SECRET_KEY=change-me-to-a-long-random-secret-key

# Flask environment  (development | production)
FLASK_ENV=development

# Optional: OpenWeather API key for live  data (future integration)
# OPENWEATHER_API_KEY=your_openweather_api_key_here
